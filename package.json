{
  "name": "aizura-consortium",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:website\" \"npm run dev:backend\"",
    "dev:admin": "vite --config admin/vite.config.ts",
    "dev:client": "vite --config client/vite.config.ts",
    "dev:website": "vite --config website/vite.config.ts",
    "dev:backend": "tsx watch backend/src/index.ts",
    "dev:all": "concurrently \"npm run dev:admin\" \"npm run dev:client\" \"npm run dev:website\" \"npm run dev:backend\"",
    "build": "npm run build:admin && npm run build:client && npm run build:website && npm run build:backend",
    "build:admin": "vite build --config admin/vite.config.ts",
    "build:client": "vite build --config client/vite.config.ts",
    "build:website": "vite build --config website/vite.config.ts",
    "build:backend": "tsc -p tsconfig.backend.json",
    "lint": "eslint .",
    "preview:admin": "vite preview --config admin/vite.config.ts",
    "preview:client": "vite preview --config client/vite.config.ts",
    "preview:website": "vite preview --config website/vite.config.ts",
    "typecheck": "tsc --noEmit -p admin/tsconfig.json && tsc --noEmit -p client/tsconfig.json && tsc --noEmit -p website/tsconfig.json && tsc --noEmit -p tsconfig.backend.json",
    "typecheck:watch": "tsc --noEmit --watch",
    "typecheck:strict": "tsc --noEmit --strict --noImplicitAny",
    "lint:types": "eslint . --ext .ts,.tsx",
    "validate:types": "npm run typecheck && npm run lint:types",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "validate:shared": "tsx scripts/validate-shared-imports.ts",
    "analyze:shared": "tsx scripts/analyze-shared-usage.ts",
    "generate:component": "tsx scripts/create-shared-component.ts",
    "generate:hook": "tsx scripts/create-shared-hook.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.9.1",
    "@google/generative-ai": "^0.1.3",
    "@supabase/supabase-js": "^2.57.4",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dompurify": "^3.3.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsdom": "^23.0.1",
    "lucide-react": "^0.344.0",
    "marked": "^11.1.0",
    "openai": "^4.20.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.9.4",
    "zod": "^3.22.4",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/cors": "^2.8.17",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^4.17.21",
    "@types/jsdom": "^21.1.6",
    "@types/node": "^20.10.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.7.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2",
    "vitest": "^1.0.4",
    "@vitest/coverage-istanbul": "^1.0.4"
  }
}

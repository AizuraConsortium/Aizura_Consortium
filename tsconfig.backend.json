{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020"],
    "moduleResolution": "bundler",
    "outDir": "./dist/backend",
    "strict": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": ["backend/**/*", "shared/types/**/*", "shared/utils/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "shared/components",
    "shared/hooks",
    "**/*.test.ts",
    "**/*.test.tsx"
  ]
}

# ===================================================================
# FRONTEND ENVIRONMENT VARIABLES - ROOT .ENV FILE
# ===================================================================
#
# This root .env file is used by ALL THREE frontend applications:
#   - admin/    (Admin Dashboard - port 5173)
#   - client/   (Client Portal - port 5174)
#   - website/  (Public Website - port 5175)
#
# Vite automatically reads these variables from the root .env file.
# No per-app configuration needed - they all share these values.
#
# Variables prefixed with VITE_ are exposed to the frontend code.
#
# ===================================================================

# Frontend API URL (points to backend server)
VITE_API_URL=http://localhost:3001

# Supabase Configuration (Frontend - Public Keys Only)
VITE_SUPABASE_URL=https://ijfzcfepkerbmtlkikzg.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Backend Supabase Configuration (in root .env for backend access)
SUPABASE_URL=https://ijfzcfepkerbmtlkikzg.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# AI Provider API Keys (Required for consortium agents)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GROK_API_KEY=your_grok_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
QWEN_API_KEY=your_qwen_api_key_here

# ===================================================================
# BACKEND ENVIRONMENT VARIABLES - BACKEND/.ENV FILE
# ===================================================================
#
# The backend server requires its own .env file at: backend/.env
#
# Copy this section to backend/.env and fill in the values:
#
# Backend Supabase Configuration
# SUPABASE_URL=https://ijfzcfepkerbmtlkikzg.supabase.co
# SUPABASE_ANON_KEY=your_supabase_anon_key_here
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
#
# AI Provider API Keys (Required for all 6 agents)
# Claude (Anthropic) - Engineering & Architecture Lead
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
#
# ChatGPT (OpenAI) - Product & Strategy Lead
# OPENAI_API_KEY=your_openai_api_key_here
#
# Grok (xAI) - GTM & Marketing Lead
# GROK_API_KEY=your_grok_api_key_here
#
# Gemini (Google) - Ops & Automation Lead
# GEMINI_API_KEY=your_gemini_api_key_here
#
# DeepSeek - Finance & Tokenomics Lead
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
#
# Qwen (Alibaba) - Risk, Compliance & Trust Lead
# QWEN_API_KEY=your_qwen_api_key_here
#
# Optional: Server Port
# PORT=3001
#
# Node Environment (development|production)
# NODE_ENV=development
#
# CORS Configuration (comma-separated list of allowed origins)
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
#
# Admin IP Whitelist (comma-separated)
# ADMIN_WHITELISTED_IPS=127.0.0.1,::1
#
# Webhook shared secret for /webhook/proposal
# The caller (Supabase trigger / pg_net) must send
#   Authorization: Bearer <WEBHOOK_PROPOSAL_SECRET>
# If unset, the endpoint fails closed (503).
# WEBHOOK_PROPOSAL_SECRET=generate_a_long_random_string_here
#
# ===================================================================
# OAUTH CONFIGURATION (Airdrop Social Connections)
# ===================================================================
#
# API Base URL (for OAuth callbacks)
# API_BASE_URL=https://aizura.ai
#
# Twitter OAuth 2.0 Configuration
# Get credentials from: https://developer.twitter.com/en/portal/dashboard
# Callback URL: https://aizura.ai/api/client/airdrop/connect/twitter/callback
# Required scopes: tweet.read, users.read, follows.read
# TWITTER_CLIENT_ID=your_twitter_client_id_here
# TWITTER_CLIENT_SECRET=your_twitter_client_secret_here
# OFFICIAL_TWITTER_USERNAME=AizuraAI
# OFFICIAL_TWITTER_ID=your_twitter_account_id_here
#
# Discord OAuth Configuration
# Get credentials from: https://discord.com/developers/applications
# Callback URL: https://aizura.ai/api/client/airdrop/connect/discord/callback
# Required scopes: identify, guilds
# DISCORD_CLIENT_ID=your_discord_client_id_here
# DISCORD_CLIENT_SECRET=your_discord_client_secret_here
# OFFICIAL_DISCORD_SERVER_ID=your_discord_server_id_here
# OFFICIAL_DISCORD_SERVER_NAME=Aizura
#
# GitHub OAuth Configuration
# Get credentials from: https://github.com/settings/developers
# Callback URL: https://aizura.ai/api/client/airdrop/connect/github/callback
# Required scopes: user:email, read:user
# GITHUB_CLIENT_ID=your_github_client_id_here
# GITHUB_CLIENT_SECRET=your_github_client_secret_here
# OFFICIAL_GITHUB_ORG=your_github_org_name_here
#
# Telegram Bot Configuration
# Get bot token from: @BotFather on Telegram
# Create bot with /newbot command
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# TELEGRAM_BOT_USERNAME=your_bot_username_here
# OFFICIAL_TELEGRAM_CHANNEL=@AizuraOfficial
# OFFICIAL_TELEGRAM_CHANNEL_USERNAME=AizuraOfficial
#
# ===================================================================

# ===================================================================
# MULTI-TENANT ARCHITECTURE - ENVIRONMENT SETUP
# ===================================================================
#
# This project now uses a multi-tenant architecture with 3 frontends:
#   - admin/    (Admin Dashboard - port 5173)
#   - client/   (Client Portal - port 5174)
#   - website/  (Public Website - port 5175)
#
# Each frontend has its own .env file. This root .env is NOT used
# by the frontends anymore. Copy this to backend/.env for backend.
#
# Frontend .env files:
#   - admin/.env
#   - client/.env
#   - website/.env
#
# Each should contain:
#   VITE_API_URL=http://localhost:3001
#   VITE_SUPABASE_URL=your_supabase_url
#   VITE_SUPABASE_ANON_KEY=your_anon_key
#
# ===================================================================

# Backend Environment Variables
# Supabase Configuration
SUPABASE_URL=https://ijfzcfepkerbmtlkikzg.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# AI Provider API Keys (Required for all 6 agents)
# Claude (Anthropic) - Engineering & Architecture Lead
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ChatGPT (OpenAI) - Product & Strategy Lead
OPENAI_API_KEY=your_openai_api_key_here

# Grok (xAI) - GTM & Marketing Lead
GROK_API_KEY=your_grok_api_key_here

# Gemini (Google) - Ops & Automation Lead
GEMINI_API_KEY=your_gemini_api_key_here

# DeepSeek - Finance & Tokenomics Lead
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Qwen (Alibaba) - Risk, Compliance & Trust Lead
QWEN_API_KEY=your_qwen_api_key_here

# Optional: Server Port
PORT=3001

# Node Environment (development|production)
# IMPORTANT: Controls security features like HSTS headers and CORS logging
# - development: HSTS disabled (HTTP allowed), minimal logging
# - production: HSTS enabled (HTTPS enforced), full security logging
NODE_ENV=development

# CORS Configuration (comma-separated list of allowed origins)
# For production, set to your actual frontend domain(s)
# Example: https://admin.aizura.com,https://client.aizura.com,https://aizura.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Admin IP Whitelist (comma-separated)
# Add your IP addresses here to access admin endpoints
# Example: 203.0.113.45,198.51.100.23
ADMIN_WHITELISTED_IPS=127.0.0.1,::1

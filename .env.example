VITE_SUPABASE_URL=https://ijfzcfepkerbmtlkikzg.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
VITE_API_URL=http://localhost:3001/api

# Backend Environment Variables
# Supabase Configuration
SUPABASE_URL=https://ijfzcfepkerbmtlkikzg.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# AI Provider API Keys (Required for all 6 agents)
# Claude (Anthropic) - Engineering & Architecture Lead
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ChatGPT (OpenAI) - Product & Strategy Lead
OPENAI_API_KEY=your_openai_api_key_here

# Grok (xAI) - GTM & Marketing Lead
GROK_API_KEY=your_grok_api_key_here

# Gemini (Google) - Ops & Automation Lead
GEMINI_API_KEY=your_gemini_api_key_here

# DeepSeek - Finance & Tokenomics Lead
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Qwen (Alibaba) - Risk, Compliance & Trust Lead
QWEN_API_KEY=your_qwen_api_key_here

# Optional: Server Port
PORT=3001

# CORS Configuration (comma-separated list of allowed origins)
# For production, set to your actual frontend domain(s)
# Example: https://aizura.yourdomain.com,https://app.aizura.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:4173

# Admin IP Whitelist (comma-separated)
# Add your IP addresses here to access admin endpoints
# Example: 203.0.113.45,198.51.100.23
ADMIN_WHITELISTED_IPS=127.0.0.1,::1

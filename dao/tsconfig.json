{
  "extends": "../tsconfig.app.json",
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.dao.tsbuildinfo",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../shared/*"],
      "@dao/*": ["./*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "../vite-env.d.ts"
  ],
  "references": [
    {
      "path": "../tsconfig.shared.json"
    }
  ]
}
